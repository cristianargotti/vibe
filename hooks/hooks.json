{
  "description": "Vibe plugin hooks — safety guards, auto-formatting, and session validation",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-dangerous-commands.sh",
            "statusMessage": "Checking command safety..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/workflow-guard.sh",
            "statusMessage": "Validating workflow..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/branch-guard.sh",
            "statusMessage": "Checking branch protection..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-lint.sh",
            "statusMessage": "Auto-formatting..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Before finishing, verify: 1) All tests pass 2) No security issues introduced 3) Code follows project conventions in .claude/rules/ 4) No secrets or PII exposed"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-config.sh",
            "statusMessage": "Validating Vibe configuration...",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
