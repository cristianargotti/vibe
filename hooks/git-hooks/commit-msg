#!/usr/bin/env bash
# Native git commit-msg hook: conventional commit validation.
# Works for ALL git clients, not just Claude Code.

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -n 1 "$COMMIT_MSG_FILE")

# Allow merge commits
if echo "$COMMIT_MSG" | grep -qiE '^Merge[[:space:]]'; then
  exit 0
fi

# Allow fixup and squash commits (used during interactive rebase)
if echo "$COMMIT_MSG" | grep -qE '^(fixup|squash)![[:space:]]'; then
  exit 0
fi

# Validate conventional commit format
if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|refactor|docs|test|chore|style|perf|ci|build|revert)(\(.+\))?!?:[[:space:]]'; then
  echo "ERROR: Commit message does not follow conventional commits format."
  echo ""
  echo "Expected: type(scope): description"
  echo "Valid types: feat, fix, refactor, docs, test, chore, style, perf, ci, build, revert"
  echo ""
  echo "Examples:"
  echo "  feat: add user authentication"
  echo "  fix(auth): resolve token expiration bug"
  echo "  refactor(api)!: restructure endpoint naming"
  echo ""
  echo "Your message: $COMMIT_MSG"
  exit 1
fi

exit 0
